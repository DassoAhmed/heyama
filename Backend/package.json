{
  "name": "backend",
  "version": "1.0.0",
  "description": "Heyama Backend API",
  "main": "dist/main.js",
  "scripts": {
    "build": "node --max_old_space_size=512 ./node_modules/@nestjs/cli/bin/nest.js build",
    "start": "node --max_old_space_size=512 dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node --max_old_space_size=512 dist/main",
    "prestart": "npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["nestjs", "api", "heyama"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@types/multer": "^2.2.0",
    "@types/multer-s3": "^3.0.3",
    "@types/node": "^26.1.1",
    "@types/uuid": "^10.0.0"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/platform-socket.io": "^11.1.28",
    "@nestjs/websockets": "^11.1.28",
    "aws-sdk": "^2.1693.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "mongoose": "^9.8.0",
    "multer": "^2.2.0",
    "multer-s3": "^3.0.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
