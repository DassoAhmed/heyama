{
  "version": 2,
  "builds": [
    {
      "src": "src/main.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/main.ts"
    }
  ],
  "env": {
    "NODE_OPTIONS": "--max-old-space-size=1024",
    "NPM_CONFIG_PRODUCTION": "false"
  },
  "installCommand": "npm install --no-audit --no-fund --legacy-peer-deps",
  "buildCommand": "npm run build"
}