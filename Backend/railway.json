{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "node --max_old_space_size=512 dist/main",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE"
  }
}